# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Backend
NODE_ENV=development
PORT=4000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=griffy
DB_PASS=griffy_pass
DB_NAME=griffy_db

# Auth
JWT_SECRET=change_this_to_a_very_long_random_secret_in_production

# Razorpay (Payment Gateway)
# Get real keys from: https://dashboard.razorpay.com → Settings → API Keys
# Use rzp_test_* for development, rzp_live_* for production
RAZORPAY_KEY_ID=rzp_test_GriffyDummyKey1
RAZORPAY_KEY_SECRET=GriffyDummySecret_ReplaceBeforeLaunch
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_GriffyDummyKey1

# AWS (S3 for file uploads)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-south-1
AWS_S3_BUCKET=griffy-uploads

# EC2 / Hosting
# EC2 public IP or domain goes here once deployed
APP_URL=https://griffy.in
FRONTEND_URL=https://griffy.in
