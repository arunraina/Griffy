NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id
NEXT_PUBLIC_RAZORPAY_KEY_ID=your-razorpay-key-id
NEXT_PUBLIC_SITE_URL=https://griffy.in
# Leave unset in development — analytics silently no-ops until this is set.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional. Server/edge-side error monitoring only (instrumentation.ts) —
# no-op until set. There's deliberately no client-side Sentry DSN here: the
# browser SDK adds ~70kB to every page's shared bundle even when inactive,
# which conflicts with this app's Core Web Vitals goals. Revisit as a
# separate, deliberate decision if client-side error tracking becomes a
# priority.
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Optional. Server-only (never NEXT_PUBLIC_) -- gates POST /api/revalidate,
# which the API calls after an admin profile edit to refresh the public page
# immediately instead of waiting out its normal 5-minute ISR window. Must
# match the same value in the API's REVALIDATE_SECRET. Generate with:
# openssl rand -hex 32
REVALIDATE_SECRET=
