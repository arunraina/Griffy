generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  HOMEOWNER
  CONTRACTOR
  LABOUR
  SERVICE_EXPERT
  MATERIAL_SUPPLIER
  LAND_OWNER
  PROPERTY_SELLER
  BUILDER
  PROPERTY_AGENT
  ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DegreeStatus {
  PURSUING
  COMPLETED
}

enum OrderStatus {
  PLACED
  ACCEPTED
  REJECTED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProjectStatus {
  OPEN
  AWARDED
  CLOSED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ReviewTargetType {
  CONTRACTOR
  LABOUR
  SERVICE_EXPERT
  MATERIAL_SUPPLIER
  BUILDER
  PROPERTY_AGENT
  MATERIAL
  LAND
  PROPERTY
}

enum LandType {
  AGRICULTURAL
  RESIDENTIAL
  COMMERCIAL
  INDUSTRIAL
  MIXED
}

enum PropertyType {
  APARTMENT
  VILLA
  PLOT
  COMMERCIAL
  INDEPENDENT_HOUSE
}

enum FurnishingStatus {
  UNFURNISHED
  SEMI_FURNISHED
  FULLY_FURNISHED
}

// ---------------------------------------------------------------------------
// User
// id is set by the app from auth.users.id on first login — Prisma does NOT
// generate it and does NOT manage the auth schema.
// ---------------------------------------------------------------------------

model User {
  id               String   @id
  email            String   @unique
  phone            String?  @unique
  name             String
  role             UserRole
  avatarUrl        String?  @map("avatar_url")
  referredById     String?  @map("referred_by_id")
  referredBy       User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals        User[]   @relation("Referrals")
  isSuspended      Boolean  @default(false) @map("is_suspended")
  isFirstParty     Boolean  @default(false) @map("is_first_party")
  isGhost          Boolean  @default(false) @map("is_ghost")
  createdByAdminId String?  @map("created_by_admin_id")
  // Per-channel opt-out, e.g. { "whatsapp": false }. Absent key/null = on.
  notificationPrefs Json?   @map("notification_prefs")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // 1:1 supply-side profiles
  contractorProfile       ContractorProfile?
  labourProfile           LabourProfile?
  serviceExpertProfile    ServiceExpertProfile?
  materialSupplierProfile MaterialSupplierProfile?
  landOwnerProfile        LandOwnerProfile?
  propertySellerProfile   PropertySellerProfile?
  builderProfile          BuilderProfile?
  propertyAgentProfile    PropertyAgentProfile?

  // transactional relations
  orders                     Order[]
  bookingsAsCustomer         Booking[]        @relation("BookingCustomer")
  bookingsAsProvider         Booking[]        @relation("BookingProvider")
  reviewsGiven               Review[]         @relation("ReviewsGiven")
  notifications              Notification[]
  projectsPosted             Project[]        @relation("ProjectOwner")
  bidsSubmitted              Bid[]            @relation("BidContractor")
  turnkeyProjectsAsCustomer  TurnkeyProject[] @relation("TurnkeyProjectCustomer")
  turnkeyProjectsAsProvider  TurnkeyProject[] @relation("TurnkeyProjectProvider")
  kycDetail                  KycDetail?
  refundsInitiated           Refund[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// Supply-side profiles — each 1:1 with User, each gated by ApprovalStatus
// ---------------------------------------------------------------------------

model ContractorProfile {
  id              String         @id @default(uuid())
  userId          String         @unique @map("user_id")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  contractorType  String         @map("contractor_type")
  tradeSkills     String[]       @map("trade_skills")
  experience      String
  serviceCities   String[]       @map("service_cities")
  licenseNumber   String?        @map("license_number")
  dailyRate       Decimal?       @map("daily_rate") @db.Decimal(10, 2)
  projectRate     Decimal?       @map("project_rate") @db.Decimal(10, 2)
  isAvailable     Boolean        @default(true) @map("is_available")
  bio             String?
  portfolioImages String[]       @map("portfolio_images")
  approvalStatus  ApprovalStatus @default(PENDING) @map("approval_status")
  rejectionReason String?        @map("rejection_reason")
  approvedAt      DateTime?      @map("approved_at")
  approvedBy      String?        @map("approved_by")
  avgRating       Float          @default(0) @map("avg_rating")
  totalReviews    Int            @default(0) @map("total_reviews")
  totalJobs       Int            @default(0) @map("total_jobs")
  completionRate  Float          @default(0) @map("completion_rate")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  searchVector    Unsupported("tsvector")? @map("search_vector")

  reviews Review[]

  @@map("contractor_profiles")
}

model LabourProfile {
  id              String         @id @default(uuid())
  userId          String         @unique @map("user_id")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillType       String         @map("skill_type")
  experience      String
  serviceCities   String[]       @map("service_cities")
  dailyRate       Decimal?       @map("daily_rate") @db.Decimal(10, 2)
  isAvailable     Boolean        @default(true) @map("is_available")
  bio             String?
  portfolioImages String[]       @map("portfolio_images")
  approvalStatus  ApprovalStatus @default(PENDING) @map("approval_status")
  rejectionReason String?        @map("rejection_reason")
  approvedAt      DateTime?      @map("approved_at")
  approvedBy      String?        @map("approved_by")
  avgRating       Float          @default(0) @map("avg_rating")
  totalReviews    Int            @default(0) @map("total_reviews")
  totalJobs       Int            @default(0) @map("total_jobs")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  searchVector    Unsupported("tsvector")? @map("search_vector")

  reviews Review[]

  @@map("labour_profiles")
}

model ServiceExpertProfile {
  id              String         @id @default(uuid())
  userId          String         @unique @map("user_id")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  expertiseType   String         @map("expertise_type")
  qualifications  String[]
  experience      String
  serviceCities   String[]       @map("service_cities")
  consultationFee Decimal?       @map("consultation_fee") @db.Decimal(10, 2)
  isAvailable     Boolean        @default(true) @map("is_available")
  bio             String?
  portfolioImages String[]       @map("portfolio_images")
  approvalStatus  ApprovalStatus @default(PENDING) @map("approval_status")
  rejectionReason String?        @map("rejection_reason")
  approvedAt      DateTime?      @map("approved_at")
  approvedBy      String?        @map("approved_by")
  avgRating       Float          @default(0) @map("avg_rating")
  totalReviews    Int            @default(0) @map("total_reviews")
  totalJobs       Int            @default(0) @map("total_jobs")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  searchVector    Unsupported("tsvector")? @map("search_vector")

  reviews Review[]

  @@map("service_expert_profiles")
}

model MaterialSupplierProfile {
  id              String         @id @default(uuid())
  userId          String         @unique @map("user_id")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName    String         @map("business_name")
  gstNumber       String?        @map("gst_number")
  businessAddress String         @map("business_address")
  deliveryCities  String[]       @map("delivery_cities")
  isAvailable     Boolean        @default(true) @map("is_available")
  approvalStatus  ApprovalStatus @default(PENDING) @map("approval_status")
  rejectionReason String?        @map("rejection_reason")
  approvedAt      DateTime?      @map("approved_at")
  approvedBy      String?        @map("approved_by")
  avgRating       Float          @default(0) @map("avg_rating")
  totalReviews    Int            @default(0) @map("total_reviews")
  totalOrders     Int            @default(0) @map("total_orders")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  materials Material[]
  reviews   Review[]

  @@map("material_supplier_profiles")
}

model LandOwnerProfile {
  id              String         @id @default(uuid())
  userId          String         @unique @map("user_id")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  govtIdVerified  Boolean        @default(false) @map("govt_id_verified")
  bio             String?
  isAvailable     Boolean        @default(true) @map("is_available")
  approvalStatus  ApprovalStatus @default(PENDING) @map("approval_status")
  rejectionReason String?        @map("rejection_reason")
  approvedAt      DateTime?      @map("approved_at")
  approvedBy      String?        @map("approved_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  lands Land[]

  @@map("land_owner_profiles")
}

model PropertySellerProfile {
  id              String         @id @default(uuid())
  userId          String         @unique @map("user_id")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  govtIdVerified  Boolean        @default(false) @map("govt_id_verified")
  bio             String?
  isAvailable     Boolean        @default(true) @map("is_available")
  approvalStatus  ApprovalStatus @default(PENDING) @map("approval_status")
  rejectionReason String?        @map("rejection_reason")
  approvedAt      DateTime?      @map("approved_at")
  approvedBy      String?        @map("approved_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  properties Property[]

  @@map("property_seller_profiles")
}

model BuilderProfile {
  id                  String         @id @default(uuid())
  userId              String         @unique @map("user_id")
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName         String         @map("company_name")
  registrationNumber  String?        @map("registration_number")
  specializations     String[]
  completedProjects   Int            @default(0) @map("completed_projects")
  serviceCities       String[]       @map("service_cities")
  bio                 String?
  portfolioImages     String[]       @map("portfolio_images")
  isAvailable         Boolean        @default(true) @map("is_available")
  approvalStatus      ApprovalStatus @default(PENDING) @map("approval_status")
  rejectionReason     String?        @map("rejection_reason")
  approvedAt          DateTime?      @map("approved_at")
  approvedBy          String?        @map("approved_by")
  avgRating           Float          @default(0) @map("avg_rating")
  totalReviews        Int            @default(0) @map("total_reviews")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  reviews Review[]

  @@map("builder_profiles")
}

model PropertyAgentProfile {
  id              String         @id @default(uuid())
  userId          String         @unique @map("user_id")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  agencyName      String?        @map("agency_name")
  licenseNumber   String?        @map("license_number")
  serviceCities   String[]       @map("service_cities")
  bio             String?
  isAvailable     Boolean        @default(true) @map("is_available")
  approvalStatus  ApprovalStatus @default(PENDING) @map("approval_status")
  rejectionReason String?        @map("rejection_reason")
  approvedAt      DateTime?      @map("approved_at")
  approvedBy      String?        @map("approved_by")
  avgRating       Float          @default(0) @map("avg_rating")
  totalReviews    Int            @default(0) @map("total_reviews")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  reviews Review[]

  @@map("property_agent_profiles")
}

// ---------------------------------------------------------------------------
// Material catalogue — owned by a MaterialSupplierProfile
// ---------------------------------------------------------------------------

model Material {
  id          String                  @id @default(uuid())
  supplierId  String                  @map("supplier_id")
  supplier    MaterialSupplierProfile @relation(fields: [supplierId], references: [id])
  name        String
  description String?
  category    String
  subcategory String
  roomTypes   String[]                @default([]) @map("room_types")
  price       Decimal                 @db.Decimal(10, 2)
  unit        String
  stock       Int                     @default(0)
  imageUrls   String[]                @map("image_urls")
  avgRating   Float                   @default(0) @map("avg_rating")
  reviewCount Int                     @default(0) @map("review_count")
  isHidden    Boolean                 @default(false) @map("is_hidden")
  isDemoted   Boolean                 @default(false) @map("is_demoted")
  moderationNote String?              @map("moderation_note")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  searchVector Unsupported("tsvector")? @map("search_vector")

  orderItems OrderItem[]
  reviews    Review[]

  @@map("materials")
}

// ---------------------------------------------------------------------------
// Order — material purchase only (no services). One Order can hold multiple
// OrderItems, one per distinct material, so a single cart checkout produces
// a single Order + single Razorpay payment.
// ---------------------------------------------------------------------------

model Order {
  id                String        @id @default(uuid())
  buyerId           String        @map("buyer_id")
  buyer             User          @relation(fields: [buyerId], references: [id])
  items             OrderItem[]
  totalAmount       Decimal       @map("total_amount") @db.Decimal(10, 2)
  status            OrderStatus   @default(PLACED)
  statusUpdatedAt   DateTime      @default(now()) @map("status_updated_at")
  shippingAddress   String?       @map("shipping_address")
  notes             String?
  paymentStatus     PaymentStatus @default(UNPAID) @map("payment_status")
  razorpayOrderId   String?       @map("razorpay_order_id")
  razorpayPaymentId String?       @map("razorpay_payment_id")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  statusEvents OrderStatusEvent[]
  refunds      Refund[]
  invoice      Invoice?

  @@map("orders")
}

// Orthogonal to OrderStatus (the fulfillment workflow) — this tracks money
// state only. Set exclusively by PaymentsService.markOrderPaid() and the
// webhook/refund handlers, never by the order-status transition logic.
enum PaymentStatus {
  UNPAID
  PAID
  FAILED
  REFUND_INITIATED
  REFUNDED
}

// Idempotency + audit ledger for every Razorpay webhook delivery, keyed on
// Razorpay's X-Razorpay-Event-Id header (not anything inside the JSON body).
// Generic across entity types (order/booking) — protects both.
model PaymentEvent {
  id                String    @id @default(uuid())
  razorpayEventId   String    @unique @map("razorpay_event_id")
  eventType         String    @map("event_type")
  razorpayOrderId   String    @map("razorpay_order_id")
  razorpayPaymentId String?   @map("razorpay_payment_id")
  payloadJson       Json      @map("payload_json")
  processedAt       DateTime? @map("processed_at")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@map("payment_events")
}

enum RefundStatus {
  INITIATED
  PROCESSED
  FAILED
}

model Refund {
  id               String       @id @default(uuid())
  orderId          String       @map("order_id")
  order            Order        @relation(fields: [orderId], references: [id])
  razorpayRefundId String?      @map("razorpay_refund_id")
  amount           Int          // paise
  reason           String
  status           RefundStatus @default(INITIATED)
  initiatedById    String       @map("initiated_by_id")
  initiatedBy      User         @relation(fields: [initiatedById], references: [id])
  createdAt        DateTime     @default(now()) @map("created_at")
  processedAt      DateTime?    @map("processed_at")

  @@map("refunds")
}

// One invoice per order, auto-generated the moment an order's paymentStatus
// hits PAID (see OrdersService.markPaid -> InvoicesService.generateForOrder).
// invoiceNumber is assigned once from invoice_number_seq and never changes.
model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique @map("invoice_number")
  orderId       String   @unique @map("order_id")
  order         Order    @relation(fields: [orderId], references: [id])
  pdfUrl        String?  @map("pdf_url")
  issuedAt      DateTime @default(now()) @map("issued_at")

  @@map("invoices")
}

model OrderStatusEvent {
  id        String      @id @default(uuid())
  orderId   String      @map("order_id")
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now()) @map("created_at")

  @@map("order_status_events")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  materialId String   @map("material_id")
  material   Material @relation(fields: [materialId], references: [id])
  quantity   Int
  unitPrice  Decimal  @map("unit_price") @db.Decimal(10, 2)
  lineTotal  Decimal  @map("line_total") @db.Decimal(10, 2)

  @@map("order_items")
}

// ---------------------------------------------------------------------------
// Booking — service hire only (contractors, labour, service-experts)
// providerRole tells the app which profile table to join for the provider.
// Material purchases go in Order, never here.
// ---------------------------------------------------------------------------

model Booking {
  id                String        @id @default(uuid())
  customerId        String        @map("customer_id")
  customer          User          @relation("BookingCustomer", fields: [customerId], references: [id])
  providerId        String        @map("provider_id")
  provider          User          @relation("BookingProvider", fields: [providerId], references: [id])
  providerRole      UserRole      @map("provider_role")
  scheduledAt       DateTime      @map("scheduled_at")
  status            BookingStatus @default(PENDING)
  notes             String?
  amount            Decimal       @db.Decimal(10, 2)
  razorpayOrderId   String?       @map("razorpay_order_id")
  razorpayPaymentId String?       @map("razorpay_payment_id")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@map("bookings")
}

// ---------------------------------------------------------------------------
// Land listing — owned by a LandOwnerProfile
// ---------------------------------------------------------------------------

model Land {
  id          String           @id @default(uuid())
  ownerId     String           @map("owner_id")
  owner       LandOwnerProfile @relation(fields: [ownerId], references: [id])
  title       String
  description String?
  landType    LandType         @map("land_type")
  areaSqFt    Decimal          @map("area_sq_ft") @db.Decimal(12, 2)
  price       Decimal          @db.Decimal(12, 2)
  location    String
  city        String
  state       String
  latitude    Float?
  longitude   Float?
  imageUrls   String[]         @map("image_urls")
  isAvailable Boolean          @default(true) @map("is_available")
  isHidden    Boolean          @default(false) @map("is_hidden")
  isDemoted   Boolean          @default(false) @map("is_demoted")
  moderationNote String?       @map("moderation_note")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  searchVector Unsupported("tsvector")? @map("search_vector")

