generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  HOMEOWNER
  CONTRACTOR
  LABOUR
  SERVICE_EXPERT
  MATERIAL_SUPPLIER
  LAND_OWNER
  PROPERTY_SELLER
  BUILDER
  PROPERTY_AGENT
  ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ReviewTargetType {
  CONTRACTOR
  LABOUR
  SERVICE_EXPERT
  MATERIAL_SUPPLIER
  BUILDER
  PROPERTY_AGENT
  MATERIAL
  LAND
  PROPERTY
}

enum LandType {
  AGRICULTURAL
  RESIDENTIAL
  COMMERCIAL
  INDUSTRIAL
  MIXED
}

enum PropertyType {
  APARTMENT
  VILLA
  PLOT
  COMMERCIAL
  INDEPENDENT_HOUSE
}

enum FurnishingStatus {
  UNFURNISHED
  SEMI_FURNISHED
  FULLY_FURNISHED
}

// ---------------------------------------------------------------------------
// User
// id is set by the app from auth.users.id on first login — Prisma does NOT
// generate it and does NOT manage the auth schema.
// ---------------------------------------------------------------------------

model User {
  id        String   @id
  email     String   @unique
  phone     String?
  name      String
  role      UserRole
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // 1:1 supply-side profiles
  contractorProfile       ContractorProfile?
  labourProfile           LabourProfile?
  serviceExpertProfile    ServiceExpertProfile?
  materialSupplierProfile MaterialSupplierProfile?
  landOwnerProfile        LandOwnerProfile?
  propertySellerProfile   PropertySellerProfile?
  builderProfile          BuilderProfile?
  propertyAgentProfile    PropertyAgentProfile?

  // transactional relations
  orders             Order[]
  bookingsAsCustomer Booking[] @relation("BookingCustomer")
  bookingsAsProvider Booking[] @relation("BookingProvider")
  reviewsGiven       Review[]  @relation("ReviewsGiven")

  @@map("users")
}

// ---------------------------------------------------------------------------
// Supply-side profiles — each 1:1 with User, each gated by ApprovalStatus
// ---------------------------------------------------------------------------

model ContractorProfile {
  id              String         @id @default(uuid())
  userId          String         @unique @map("user_id")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  contractorType  String         @map("contractor_type")
  tradeSkills     String[]       @map("trade_skills")
  experience      String
  serviceCities   String[]       @map("service_cities")
  licenseNumber   String?        @map("license_number")
  dailyRate       Decimal?       @map("daily_rate") @db.Decimal(10, 2)
  projectRate     Decimal?       @map("project_rate") @db.Decimal(10, 2)
  availability    Boolean        @default(true)
  bio             String?
  portfolioImages String[]       @map("portfolio_images")
  approvalStatus  ApprovalStatus @default(PENDING) @map("approval_status")
  rejectionReason String?        @map("rejection_reason")
  approvedAt      DateTime?      @map("approved_at")
  approvedBy      String?        @map("approved_by")
  avgRating       Float          @default(0) @map("avg_rating")
  totalReviews    Int            @default(0) @map("total_reviews")
  totalJobs       Int            @default(0) @map("total_jobs")
  completionRate  Float          @default(0) @map("completion_rate")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  reviews Review[]

  @@map("contractor_profiles")
}

model LabourProfile {
  id              String         @id @default(uuid())
  userId          String         @unique @map("user_id")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillType       String         @map("skill_type")
  experience      String
  serviceCities   String[]       @map("service_cities")
  dailyRate       Decimal?       @map("daily_rate") @db.Decimal(10, 2)
  availability    Boolean        @default(true)
  bio             String?
  portfolioImages String[]       @map("portfolio_images")
  approvalStatus  ApprovalStatus @default(PENDING) @map("approval_status")
  rejectionReason String?        @map("rejection_reason")
  approvedAt      DateTime?      @map("approved_at")
  approvedBy      String?        @map("approved_by")
  avgRating       Float          @default(0) @map("avg_rating")
  totalReviews    Int            @default(0) @map("total_reviews")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  reviews Review[]

  @@map("labour_profiles")
}

model ServiceExpertProfile {
  id              String         @id @default(uuid())
  userId          String         @unique @map("user_id")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  expertiseType   String         @map("expertise_type")
  qualifications  String[]
  experience      String
  serviceCities   String[]       @map("service_cities")
  consultationFee Decimal?       @map("consultation_fee") @db.Decimal(10, 2)
  availability    Boolean        @default(true)
  bio             String?
  portfolioImages String[]       @map("portfolio_images")
  approvalStatus  ApprovalStatus @default(PENDING) @map("approval_status")
  rejectionReason String?        @map("rejection_reason")
  approvedAt      DateTime?      @map("approved_at")
  approvedBy      String?        @map("approved_by")
  avgRating       Float          @default(0) @map("avg_rating")
  totalReviews    Int            @default(0) @map("total_reviews")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  reviews Review[]

  @@map("service_expert_profiles")
}

model MaterialSupplierProfile {
  id              String         @id @default(uuid())
  userId          String         @unique @map("user_id")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName    String         @map("business_name")
  gstNumber       String?        @map("gst_number")
  businessAddress String         @map("business_address")
  deliveryCities  String[]       @map("delivery_cities")
  approvalStatus  ApprovalStatus @default(PENDING) @map("approval_status")
  rejectionReason String?        @map("rejection_reason")
  approvedAt      DateTime?      @map("approved_at")
  approvedBy      String?        @map("approved_by")
  avgRating       Float          @default(0) @map("avg_rating")
  totalReviews    Int            @default(0) @map("total_reviews")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  materials Material[]
  reviews   Review[]

  @@map("material_supplier_profiles")
}

model LandOwnerProfile {
  id              String         @id @default(uuid())
  userId          String         @unique @map("user_id")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  govtIdVerified  Boolean        @default(false) @map("govt_id_verified")
  bio             String?
  approvalStatus  ApprovalStatus @default(PENDING) @map("approval_status")
  rejectionReason String?        @map("rejection_reason")
  approvedAt      DateTime?      @map("approved_at")
  approvedBy      String?        @map("approved_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  lands Land[]

  @@map("land_owner_profiles")
}

model PropertySellerProfile {
  id              String         @id @default(uuid())
  userId          String         @unique @map("user_id")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  govtIdVerified  Boolean        @default(false) @map("govt_id_verified")
  bio             String?
  approvalStatus  ApprovalStatus @default(PENDING) @map("approval_status")
  rejectionReason String?        @map("rejection_reason")
  approvedAt      DateTime?      @map("approved_at")
  approvedBy      String?        @map("approved_by")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  properties Property[]

  @@map("property_seller_profiles")
}

model BuilderProfile {
  id                  String         @id @default(uuid())
  userId              String         @unique @map("user_id")
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName         String         @map("company_name")
  registrationNumber  String?        @map("registration_number")
  specializations     String[]
  completedProjects   Int            @default(0) @map("completed_projects")
  serviceCities       String[]       @map("service_cities")
  bio                 String?
  portfolioImages     String[]       @map("portfolio_images")
  approvalStatus      ApprovalStatus @default(PENDING) @map("approval_status")
  rejectionReason     String?        @map("rejection_reason")
  approvedAt          DateTime?      @map("approved_at")
  approvedBy          String?        @map("approved_by")
  avgRating           Float          @default(0) @map("avg_rating")
  totalReviews        Int            @default(0) @map("total_reviews")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  reviews Review[]

  @@map("builder_profiles")
}

model PropertyAgentProfile {
  id              String         @id @default(uuid())
  userId          String         @unique @map("user_id")
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  agencyName      String?        @map("agency_name")
  licenseNumber   String?        @map("license_number")
  serviceCities   String[]       @map("service_cities")
  bio             String?
  approvalStatus  ApprovalStatus @default(PENDING) @map("approval_status")
  rejectionReason String?        @map("rejection_reason")
  approvedAt      DateTime?      @map("approved_at")
  approvedBy      String?        @map("approved_by")
  avgRating       Float          @default(0) @map("avg_rating")
  totalReviews    Int            @default(0) @map("total_reviews")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  reviews Review[]

  @@map("property_agent_profiles")
}

// ---------------------------------------------------------------------------
// Material catalogue — owned by a MaterialSupplierProfile
// ---------------------------------------------------------------------------

model Material {
  id          String                  @id @default(uuid())
  supplierId  String                  @map("supplier_id")
  supplier    MaterialSupplierProfile @relation(fields: [supplierId], references: [id])
  name        String
  description String?
  category    String
  subcategory String
  price       Decimal                 @db.Decimal(10, 2)
  unit        String
  stock       Int                     @default(0)
  imageUrls   String[]                @map("image_urls")
  avgRating   Float                   @default(0) @map("avg_rating")
  reviewCount Int                     @default(0) @map("review_count")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")

  orderItems OrderItem[]
  reviews    Review[]

  @@map("materials")
}

// ---------------------------------------------------------------------------
// Order — material purchase only (no services). One Order can hold multiple
// OrderItems, one per distinct material, so a single cart checkout produces
// a single Order + single Razorpay payment.
// ---------------------------------------------------------------------------

model Order {
  id                String      @id @default(uuid())
  buyerId           String      @map("buyer_id")
  buyer             User        @relation(fields: [buyerId], references: [id])
  items             OrderItem[]
  totalAmount       Decimal     @map("total_amount") @db.Decimal(10, 2)
  status            OrderStatus @default(PENDING)
  shippingAddress   String?     @map("shipping_address")
  notes             String?
  razorpayOrderId   String?     @map("razorpay_order_id")
  razorpayPaymentId String?     @map("razorpay_payment_id")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  @@map("orders")
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String   @map("order_id")
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  materialId String   @map("material_id")
  material   Material @relation(fields: [materialId], references: [id])
  quantity   Int
  unitPrice  Decimal  @map("unit_price") @db.Decimal(10, 2)
  lineTotal  Decimal  @map("line_total") @db.Decimal(10, 2)

  @@map("order_items")
}

// ---------------------------------------------------------------------------
// Booking — service hire only (contractors, labour, service-experts)
// providerRole tells the app which profile table to join for the provider.
// Material purchases go in Order, never here.
// ---------------------------------------------------------------------------

model Booking {
  id                String        @id @default(uuid())
  customerId        String        @map("customer_id")
  customer          User          @relation("BookingCustomer", fields: [customerId], references: [id])
  providerId        String        @map("provider_id")
  provider          User          @relation("BookingProvider", fields: [providerId], references: [id])
  providerRole      UserRole      @map("provider_role")
  scheduledAt       DateTime      @map("scheduled_at")
  status            BookingStatus @default(PENDING)
  notes             String?
  amount            Decimal       @db.Decimal(10, 2)
  razorpayOrderId   String?       @map("razorpay_order_id")
  razorpayPaymentId String?       @map("razorpay_payment_id")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@map("bookings")
}

// ---------------------------------------------------------------------------
// Land listing — owned by a LandOwnerProfile
// ---------------------------------------------------------------------------

model Land {
  id          String           @id @default(uuid())
  ownerId     String           @map("owner_id")
  owner       LandOwnerProfile @relation(fields: [ownerId], references: [id])
  title       String
  description String?
  landType    LandType         @map("land_type")
  areaSqFt    Decimal          @map("area_sq_ft") @db.Decimal(12, 2)
  price       Decimal          @db.Decimal(12, 2)
  location    String
  city        String
  state       String
  latitude    Float?
  longitude   Float?
  imageUrls   String[]         @map("image_urls")
  isAvailable Boolean          @default(true) @map("is_available")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  reviews Review[]

  @@map("lands")
}

// ---------------------------------------------------------------------------
// Property listing — owned by a PropertySellerProfile
// ---------------------------------------------------------------------------

model Property {
  id           String                @id @default(uuid())
  sellerId     String                @map("seller_id")
  seller       PropertySellerProfile @relation(fields: [sellerId], references: [id])
  title        String
  description  String?
  propertyType PropertyType          @map("property_type")
  furnishing   FurnishingStatus
  areaSqFt     Decimal               @map("area_sq_ft") @db.Decimal(12, 2)
  price        Decimal               @db.Decimal(12, 2)
  bedrooms     Int?
  bathrooms    Int?
  location     String
  city         String
  state        String
  latitude     Float?
  longitude    Float?
  imageUrls    String[]              @map("image_urls")
  listingType  String               @default("buy") @map("listing_type")
  isAvailable  Boolean               @default(true) @map("is_available")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  reviews Review[]

  @@map("properties")
}

// ---------------------------------------------------------------------------
// Review — polymorphic; exactly one nullable FK must be set (enforced in service)
// ---------------------------------------------------------------------------

model Review {
  id                       String                   @id @default(uuid())
  reviewerId               String                   @map("reviewer_id")
  reviewer                 User                     @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  targetType               ReviewTargetType         @map("target_type")
  rating                   Int
  comment                  String?
  contractorProfileId      String?                  @map("contractor_profile_id")
  contractorProfile        ContractorProfile?       @relation(fields: [contractorProfileId], references: [id])
  labourProfileId          String?                  @map("labour_profile_id")
  labourProfile            LabourProfile?           @relation(fields: [labourProfileId], references: [id])
  serviceExpertProfileId   String?                  @map("service_expert_profile_id")
  serviceExpertProfile     ServiceExpertProfile?    @relation(fields: [serviceExpertProfileId], references: [id])
  materialSupplierProfileId String?                 @map("material_supplier_profile_id")
  materialSupplierProfile  MaterialSupplierProfile? @relation(fields: [materialSupplierProfileId], references: [id])
  builderProfileId         String?                  @map("builder_profile_id")
  builderProfile           BuilderProfile?          @relation(fields: [builderProfileId], references: [id])
  propertyAgentProfileId   String?                  @map("property_agent_profile_id")
  propertyAgentProfile     PropertyAgentProfile?    @relation(fields: [propertyAgentProfileId], references: [id])
  materialId               String?                  @map("material_id")
  material                 Material?                @relation(fields: [materialId], references: [id])
  landId                   String?                  @map("land_id")
  land                     Land?                    @relation(fields: [landId], references: [id])
  propertyId               String?                  @map("property_id")
  property                 Property?                @relation(fields: [propertyId], references: [id])
  createdAt                DateTime                 @default(now()) @map("created_at")
  updatedAt                DateTime                 @updatedAt @map("updated_at")

  @@map("reviews")
}

// ---------------------------------------------------------------------------
// WhatsApp OTP — unchanged
// ---------------------------------------------------------------------------

model WhatsappOtp {
  id        String   @id @default(uuid())
  phone     String
  otp       String
  verified  Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("whatsapp_otps")
}
