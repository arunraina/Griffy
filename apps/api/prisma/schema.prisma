  @@map("lands")
}

// ---------------------------------------------------------------------------
// Property listing — owned by a PropertySellerProfile
// ---------------------------------------------------------------------------

model Property {
  id           String                @id @default(uuid())
  sellerId     String                @map("seller_id")
  seller       PropertySellerProfile @relation(fields: [sellerId], references: [id])
  title        String
  description  String?
  propertyType PropertyType          @map("property_type")
  furnishing   FurnishingStatus
  areaSqFt     Decimal               @map("area_sq_ft") @db.Decimal(12, 2)
  price        Decimal               @db.Decimal(12, 2)
  bedrooms     Int?
  bathrooms    Int?
  location     String
  city         String
  state        String
  latitude     Float?
  longitude    Float?
  imageUrls    String[]              @map("image_urls")
  listingType  String               @default("buy") @map("listing_type")
  isAvailable  Boolean               @default(true) @map("is_available")
  isHidden     Boolean               @default(false) @map("is_hidden")
  isDemoted    Boolean               @default(false) @map("is_demoted")
  moderationNote String?             @map("moderation_note")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  searchVector Unsupported("tsvector")? @map("search_vector")

  reviews Review[]

  @@map("properties")
}

// ---------------------------------------------------------------------------
// Review — polymorphic; exactly one nullable FK must be set (enforced in service)
// ---------------------------------------------------------------------------

model Review {
  id                       String                   @id @default(uuid())
  reviewerId               String                   @map("reviewer_id")
  reviewer                 User                     @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  targetType               ReviewTargetType         @map("target_type")
  rating                   Int
  comment                  String?
  contractorProfileId      String?                  @map("contractor_profile_id")
  contractorProfile        ContractorProfile?       @relation(fields: [contractorProfileId], references: [id])
  labourProfileId          String?                  @map("labour_profile_id")
  labourProfile            LabourProfile?           @relation(fields: [labourProfileId], references: [id])
  serviceExpertProfileId   String?                  @map("service_expert_profile_id")
  serviceExpertProfile     ServiceExpertProfile?    @relation(fields: [serviceExpertProfileId], references: [id])
  materialSupplierProfileId String?                 @map("material_supplier_profile_id")
  materialSupplierProfile  MaterialSupplierProfile? @relation(fields: [materialSupplierProfileId], references: [id])
  builderProfileId         String?                  @map("builder_profile_id")
  builderProfile           BuilderProfile?          @relation(fields: [builderProfileId], references: [id])
  propertyAgentProfileId   String?                  @map("property_agent_profile_id")
  propertyAgentProfile     PropertyAgentProfile?    @relation(fields: [propertyAgentProfileId], references: [id])
  materialId               String?                  @map("material_id")
  material                 Material?                @relation(fields: [materialId], references: [id])
  landId                   String?                  @map("land_id")
  land                     Land?                    @relation(fields: [landId], references: [id])
  propertyId               String?                  @map("property_id")
  property                 Property?                @relation(fields: [propertyId], references: [id])
  isHidden                 Boolean                  @default(false) @map("is_hidden")
  isDemoted                Boolean                  @default(false) @map("is_demoted")
  moderationNote           String?                  @map("moderation_note")
  createdAt                DateTime                 @default(now()) @map("created_at")
  updatedAt                DateTime                 @updatedAt @map("updated_at")

  @@map("reviews")
}

// ---------------------------------------------------------------------------
// WhatsApp OTP — unchanged
// ---------------------------------------------------------------------------

model WhatsappOtp {
  id        String   @id @default(uuid())
  phone     String
  otp       String
  verified  Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("whatsapp_otps")
}

// ---------------------------------------------------------------------------
// Notifications — multi-channel (in-app, WhatsApp, email) fan-out via
// NotificationsService.notify(). See notification-templates.ts for copy.
// ---------------------------------------------------------------------------

enum NotificationChannel {
  IN_APP
  WHATSAPP
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

// `type` is a free-string event key (e.g. "booking.created"), not an enum —
// new events are added in notification-templates.ts without a migration.
// notify() writes one row per channel attempted for a single event: an
// IN_APP row always, plus a WHATSAPP and/or EMAIL row recording that
// channel's delivery outcome. The bell only ever reads channel=IN_APP.
model Notification {
  id        String              @id @default(uuid())
  userId    String              @map("user_id")
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  linkUrl   String?             @map("link_url")
  isRead    Boolean             @default(false) @map("is_read")
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(SENT)
  createdAt DateTime            @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([userId, channel])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// Open projects marketplace — homeowners post a project, contractors bid.
// ---------------------------------------------------------------------------

model Project {
  id          String        @id @default(uuid())
  ownerId     String        @map("owner_id")
  owner       User          @relation("ProjectOwner", fields: [ownerId], references: [id])
  projectType String        @map("project_type")
  title       String
  description String
  city        String
  state       String
  budgetMin   Decimal       @map("budget_min") @db.Decimal(12, 2)
  budgetMax   Decimal       @map("budget_max") @db.Decimal(12, 2)
  timeline    String
  status      ProjectStatus @default(OPEN)
  isHidden    Boolean       @default(false) @map("is_hidden")
  isDemoted   Boolean       @default(false) @map("is_demoted")
  moderationNote String?    @map("moderation_note")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  bids Bid[]

  @@map("projects")
}

model Bid {
  id           String    @id @default(uuid())
  projectId    String    @map("project_id")
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractorId String    @map("contractor_id")
  contractor   User      @relation("BidContractor", fields: [contractorId], references: [id])
  bidAmount    Decimal   @map("bid_amount") @db.Decimal(12, 2)
  message      String
  status       BidStatus @default(PENDING)
  createdAt    DateTime  @default(now()) @map("created_at")

  @@unique([projectId, contractorId])
  @@map("bids")
}

// ---------------------------------------------------------------------------
// Career applications — internship applies from the public Careers page.
// No auth required to apply; applicants are prospective, not existing users.

model CareerApplication {
  id             String       @id @default(uuid())
  role           String
  name           String
  email          String
  resumeUrl      String       @map("resume_url")
  institute      String
  courseOrDegree String       @map("course_or_degree")
  degreeStatus   DegreeStatus @map("degree_status")
  graduationYear Int          @map("graduation_year")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("career_applications")
}

// ---------------------------------------------------------------------------
// Early access signups — email capture for the mobile app / new-feature
// waitlist. No auth required; a signup here is not a Griffy account.

model EarlyAccessSignup {
  id        String   @id @default(uuid())
  email     String   @unique
  interest  String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("early_access_signups")
}

// ---------------------------------------------------------------------------
// Homepage promotional banners — admin-managed
// ---------------------------------------------------------------------------

model Banner {
  id        String   @id @default(uuid())
  title     String
  imageUrl  String   @map("image_url")
  linkUrl   String?  @map("link_url")
  active    Boolean  @default(true)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("banners")
}

// ---------------------------------------------------------------------------
// Turnkey construction & land-plotting — Griffy (or a contractor) takes on
// an entire build end-to-end. Distinct from the open-bid Project/Bid model
// above: no bidding, one assigned provider, tracked via percent-complete
// updates rather than a status a homeowner sets themselves.
// ---------------------------------------------------------------------------

enum TurnkeyProjectType {
  TURNKEY
  LAND_PLOTTING
}

enum TurnkeyProjectStatus {
  REQUESTED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model TurnkeyProject {
  id              String               @id @default(uuid())
  customerId      String               @map("customer_id")
  customer        User                 @relation("TurnkeyProjectCustomer", fields: [customerId], references: [id])
  providerId      String?              @map("provider_id")
  provider        User?                @relation("TurnkeyProjectProvider", fields: [providerId], references: [id])
  type            TurnkeyProjectType
  title           String
  description     String
  budget          Decimal              @db.Decimal(12, 2)
  status          TurnkeyProjectStatus @default(REQUESTED)
  startDate       DateTime?            @map("start_date")
  targetEndDate   DateTime?            @map("target_end_date")
  percentComplete Int                  @default(0) @map("percent_complete")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  updates TurnkeyProjectUpdate[]

  @@map("turnkey_projects")
}

model TurnkeyProjectUpdate {
  id              String         @id @default(uuid())
  projectId       String         @map("project_id")
  project         TurnkeyProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  note            String
  percentComplete Int            @map("percent_complete")
  imageUrls       String[]       @default([]) @map("image_urls")
  createdAt       DateTime       @default(now()) @map("created_at")

  @@map("turnkey_project_updates")
}

// ---------------------------------------------------------------------------
// KYC — identity/bank verification for supply-side accounts, ahead of
// escrow-based payouts. One record per user; independent of profile
// approval (a contractor profile can be APPROVED while KYC is still
// PENDING — they just can't receive escrow payouts until both are done).
// ---------------------------------------------------------------------------

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

model KycDetail {
  id                     String    @id @default(uuid())
  userId                 String    @unique @map("user_id")
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  aadhaarNumber          String?   @map("aadhaar_number")
  panNumber              String?   @map("pan_number")
  gstNumber              String?   @map("gst_number")
  businessName           String?   @map("business_name")
  bankAccountNumber      String?   @map("bank_account_number")
  bankIfsc               String?   @map("bank_ifsc")
  bankAccountHolderName  String?   @map("bank_account_holder_name")
  panCardUrl             String?   @map("pan_card_url")
  bankProofUrl           String?   @map("bank_proof_url")
  status                 KycStatus @default(NOT_SUBMITTED)
  rejectionReason        String?   @map("rejection_reason")
  submittedAt            DateTime? @map("submitted_at")
  verifiedAt             DateTime? @map("verified_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  @@map("kyc_details")
}
