DATABASE_URL=postgresql://user:password@localhost:5432/construction_partner

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Signs short-lived (1h) admin-impersonation tokens -- separate from any
# other secret in this file, since Supabase's own JWTs are verified against
# its JWKS, not this. Generate with: openssl rand -hex 48
IMPERSONATION_JWT_SECRET=

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=griffy-assets

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Firebase Admin SDK -- verifies Firebase ID tokens from phone auth server-side.
# Generate via Firebase Console -> Project Settings -> Service Accounts ->
# Generate new private key. FIREBASE_PRIVATE_KEY keeps its \n escapes literal
# here; code un-escapes them before passing to firebase-admin.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional — email fallback logs to console instead of sending if unset.
RESEND_API_KEY=
EMAIL_FROM=Griffy <notifications@griffy.in>

# Used to build links in email notifications (no hardcoded domain).
APP_BASE_URL=http://localhost:3000

# Used to build publicly-servable URLs for avatar/portfolio images uploaded
# to local disk when AWS_* isn't configured — unused once S3 is live.
API_BASE_URL=http://localhost:3001

# Invoice seller block. Leave GRIFFY_GSTIN unset until GST registration is
# done — invoices render "GSTIN: Applied For" and skip the GST line
# entirely. Once registered, setting GRIFFY_GSTIN + GST_RATE is the only
# change needed to start charging GST on invoices.
GRIFFY_BUSINESS_NAME=Griffy
GRIFFY_BUSINESS_ADDRESS=
GRIFFY_GSTIN=
GST_RATE=18

PORT=3001
ALLOWED_ORIGINS=http://localhost:3000
