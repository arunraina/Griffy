DATABASE_URL=postgresql://user:password@localhost:5432/construction_partner

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=griffy-assets

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# Optional — email fallback logs to console instead of sending if unset.
RESEND_API_KEY=
EMAIL_FROM=Griffy <notifications@griffy.in>

# Used to build links in WhatsApp/email notifications (no hardcoded domain).
APP_BASE_URL=http://localhost:3000

# Used to build publicly-servable URLs for avatar/portfolio images uploaded
# to local disk when AWS_* isn't configured — unused once S3 is live.
API_BASE_URL=http://localhost:3001

# Invoice seller block. Leave GRIFFY_GSTIN unset until GST registration is
# done — invoices render "GSTIN: Applied For" and skip the GST line
# entirely. Once registered, setting GRIFFY_GSTIN + GST_RATE is the only
# change needed to start charging GST on invoices.
GRIFFY_BUSINESS_NAME=Griffy
GRIFFY_BUSINESS_ADDRESS=
GRIFFY_GSTIN=
GST_RATE=18

PORT=3001
ALLOWED_ORIGINS=http://localhost:3000
